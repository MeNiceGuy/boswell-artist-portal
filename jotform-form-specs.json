{
  "forms": [
    {
      "key": "secureWorkOrderIntake",
      "title": "Boswell Artist Portal - Secure Work Order Intake",
      "notificationSubject": "New artist work order intake - {artistStageName} - {songOrReleaseTitle}",
      "confirmationMessage": "Thank you. Your work order intake was received. Keep your Stripe receipt for your records. Boswell Consulting Group will review the intake and follow up if required information is missing. Do not send passwords by email or through open text fields.",
      "fields": [
        { "section": "Artist Information", "label": "Legal name", "type": "fullName", "required": true },
        { "section": "Artist Information", "label": "Artist/stage name", "name": "artistStageName", "type": "shortText", "required": true },
        { "section": "Artist Information", "label": "Email", "type": "email", "required": true },
        { "section": "Artist Information", "label": "Phone", "type": "phone", "required": false },
        { "section": "Artist Information", "label": "Country", "type": "shortText", "required": true },
        { "section": "Artist Information", "label": "State/province", "type": "shortText", "required": false },
        { "section": "Artist Information", "label": "Preferred contact method", "type": "dropdown", "required": true, "options": ["Email", "Phone", "Text message", "Video call"] },
        { "section": "Artist Information", "label": "Are you 18 or older?", "type": "yesNo", "required": true },
        { "section": "Artist Information", "label": "If under 18, parent/guardian contact", "type": "longText", "required": false },
        { "section": "Payment", "label": "Package purchased", "type": "dropdown", "required": true, "options": ["Starter Release Bundle - $97", "Royalty Account Setup - $49", "Single Song Registration - $29", "Release Pack - $97", "Extra Track Add-On - $5", "Catalog Cleanup Sprint - $200", "Monthly Royalty Admin Desk - $49/mo"] },
        { "section": "Payment", "label": "Stripe receipt email", "type": "email", "required": true },
        { "section": "Payment", "label": "Stripe payment confirmation", "type": "fileUpload", "required": false },
        { "section": "Portal Selection", "label": "Portals needing support", "type": "multipleChoice", "required": true, "options": ["BMI", "ASCAP", "The MLC", "SoundExchange", "Not sure / need review"] },
        { "section": "Current Account Status", "label": "Current account status", "type": "multipleChoice", "required": true, "options": ["I already have BMI access", "I already have ASCAP access", "I already have The MLC access", "I already have SoundExchange access", "I need account setup support", "I am not sure"] },
        { "section": "Song or Release Details", "label": "Work order type", "type": "dropdown", "required": true, "options": ["Single song", "EP", "Album", "Old catalog cleanup", "Account setup only", "Missing-information review"] },
        { "section": "Song or Release Details", "label": "Song title", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "Alternate title", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "Recording title, if different", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "Primary artist", "type": "shortText", "required": true },
        { "section": "Song or Release Details", "label": "Featured artists", "type": "longText", "required": false },
        { "section": "Song or Release Details", "label": "Writers", "type": "longText", "required": false },
        { "section": "Song or Release Details", "label": "Producers", "type": "longText", "required": false },
        { "section": "Song or Release Details", "label": "Master owner", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "Publisher or self-administered status", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "Release date", "type": "date", "required": false },
        { "section": "Song or Release Details", "label": "Distributor", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "UPC", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "ISRC", "type": "shortText", "required": false },
        { "section": "Song or Release Details", "label": "DSP/store links", "type": "longText", "required": false },
        { "section": "Song or Release Details", "label": "Lyrics available?", "type": "yesNo", "required": false },
        { "section": "Song or Release Details", "label": "Explicit content?", "type": "yesNo", "required": false },
        { "section": "Song or Release Details", "label": "Is this already released?", "type": "yesNo", "required": true },
        { "section": "Song or Release Details", "label": "Is this already registered anywhere?", "type": "longText", "required": false },
        { "section": "Splits and Ownership", "label": "Writer split percentages", "type": "longText", "required": false },
        { "section": "Splits and Ownership", "label": "Publisher split percentages", "type": "longText", "required": false },
        { "section": "Splits and Ownership", "label": "Master ownership percentages", "type": "longText", "required": false },
        { "section": "Splits and Ownership", "label": "Featured artist agreement status", "type": "dropdown", "required": false, "options": ["Signed", "Verbal only", "Not applicable", "Not sure"] },
        { "section": "Splits and Ownership", "label": "Producer agreement status", "type": "dropdown", "required": false, "options": ["Signed", "Verbal only", "Not applicable", "Not sure"] },
        { "section": "Splits and Ownership", "label": "Any unresolved split disputes?", "type": "yesNo", "required": true },
        { "section": "Splits and Ownership", "label": "Any samples or interpolations?", "type": "yesNo", "required": true },
        { "section": "Splits and Ownership", "label": "Any cover song involved?", "type": "yesNo", "required": true },
        { "section": "Splits and Ownership", "label": "Ownership, sample, cover, or dispute notes", "type": "longText", "required": false },
        { "section": "Uploads", "label": "Split sheet or agreement upload", "type": "fileUpload", "required": false },
        { "section": "Uploads", "label": "Distributor or release proof upload", "type": "fileUpload", "required": false },
        { "section": "Uploads", "label": "Existing registration confirmations", "type": "fileUpload", "required": false },
        { "section": "Uploads", "label": "Prior royalty statements", "type": "fileUpload", "required": false },
        { "section": "Portal Task Request", "label": "Portal tasks requested", "type": "multipleChoice", "required": true, "options": ["Register composition with selected PRO", "Register or claim composition with The MLC", "Register or claim recording with SoundExchange", "Review existing portal entries", "Correct missing metadata", "Prepare missing-information report only"] },
        { "section": "Credentials and Access", "label": "Preferred secure access method", "type": "dropdown", "required": true, "options": ["Artist will log in during a screen-share session", "Artist will create limited access if portal allows it", "Artist will provide credentials through an approved password manager", "Artist only wants instructions, not done-for-you login support"] },
        { "section": "Authorization", "label": "I authorize Boswell Consulting Group to perform administrative royalty-registration support for the songs, recordings, and portals I selected in this work order. I understand this is administrative support only and does not guarantee royalties, income, approval, collection, legal ownership, tax treatment, or platform acceptance.", "type": "checkbox", "required": true },
        { "section": "Authorization", "label": "I confirm that the information I submitted is accurate to the best of my knowledge and that I have the right to request administrative support for the listed songs and recordings.", "type": "checkbox", "required": true },
        { "section": "Authorization", "label": "I understand that unresolved splits, missing data, samples, covers, ownership disputes, or incomplete portal access may delay or block completion.", "type": "checkbox", "required": true },
        { "section": "Authorization", "label": "I understand passwords must not be submitted by normal email or open form fields.", "type": "checkbox", "required": true }
      ]
    },
    {
      "key": "missingInformationUpload",
      "title": "Boswell Artist Portal - Missing Information Upload",
      "notificationSubject": "Missing information response - {artistStageName} - {songOrReleaseTitle}",
      "confirmationMessage": "Thank you. Your missing-information response was received. Boswell Consulting Group will review the update and contact you if anything else is required. Do not send passwords by email or through open text fields.",
      "fields": [
        { "section": "Work Order", "label": "Work order ID", "type": "shortText", "required": false },
        { "section": "Work Order", "label": "Artist/stage name", "name": "artistStageName", "type": "shortText", "required": true },
        { "section": "Work Order", "label": "Email", "type": "email", "required": true },
        { "section": "Work Order", "label": "Song/release title", "name": "songOrReleaseTitle", "type": "shortText", "required": true },
        { "section": "Missing Information", "label": "Missing information being provided", "type": "longText", "required": true },
        { "section": "Missing Information", "label": "Files to upload", "type": "fileUpload", "required": false },
        { "section": "Missing Information", "label": "Portal or task this relates to", "type": "multipleChoice", "required": false, "options": ["BMI", "ASCAP", "The MLC", "SoundExchange", "Distributor metadata", "Split/ownership details", "Other"] },
        { "section": "Missing Information", "label": "Deadline from request", "type": "date", "required": false },
        { "section": "Access", "label": "Secure access preference update", "type": "dropdown", "required": false, "options": ["Screen-share login session", "Password manager shared item", "Limited access if available", "Instructions only"] },
        { "section": "Authorization", "label": "I understand passwords must not be submitted by normal email or open form fields.", "type": "checkbox", "required": true },
        { "section": "Authorization", "label": "I confirm this information is accurate to the best of my knowledge.", "type": "checkbox", "required": true }
      ]
    }
  ]
}

